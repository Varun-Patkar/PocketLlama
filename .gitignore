# ══════════════════════════════════════════════════════════════
# PocketLlama — Root .gitignore
# ══════════════════════════════════════════════════════════════

# ── OS files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── IDE / Editor ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Environment files (secrets) ──────────────────────────────
.env
.env.local
.env*.local
# Keep .env.example as a template
!.env.example

# ══════════════════════════════════════════════════════════════
# Python (server/)
# ══════════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/
*.whl

# ══════════════════════════════════════════════════════════════
# Node / React Native (mobile/)
# ══════════════════════════════════════════════════════════════
node_modules/

# Expo
.expo/
web-build/
expo-env.d.ts

# Metro
.metro-health-check*

# Native build folders (generated by expo prebuild)
mobile/ios/
mobile/android/

# Kotlin
.kotlin/

# Signing keys
*.jks
*.p8
*.p12
*.key
*.pem
*.mobileprovision
*.orig.*

# Debug logs
npm-debug.*
yarn-debug.*
yarn-error.*

# TypeScript
*.tsbuildinfo

# ── APK builds (too large for GitHub, use Releases instead) ──
*.apk
