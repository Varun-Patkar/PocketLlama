# PocketLlama Server Configuration
# Copy this file to .env and adjust as needed.

# Port the proxy server listens on
PROXY_PORT=8080

# Port Ollama is running on (default 11434)
OLLAMA_PORT=11434

# Enable Speech-to-Text (requires faster-whisper: pip install faster-whisper)
ENABLE_STT=false

# Whisper model size: tiny, base, small, medium, large
# Smaller = faster, larger = more accurate
WHISPER_MODEL=small
